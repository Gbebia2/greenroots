<section class="products">
  <h2>Our Products</h2>
  <div class="product-container">
    <% products.forEach(product => { %>
      <div class="product-card">
        <img src="<%= product.image %>" alt="<%= product.name %>">
        <h3><%= product.name %></h3>
        <p>Short description for <%= product.name %>.</p>
        <a href="/products/<%= product.id %>" class="btn-order">Order</a>
      </div>
    <% }) %>
  </div>
</section>